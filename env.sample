# Rename this file to .env.local when running locally
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# NextAuth secret for JWT encryption
NEXTAUTH_SECRET="replace_with_random_long_secret"

# Google Tag Manager ID for analytics (public)
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Shared secret for syncing/migrating data & protected API routes
SYNC_SECRET="replace_with_strong_secret"

# Production site URL (used by sync scripts)
PROD_URL="https://example.com"
